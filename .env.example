# 文本模型（推荐 DeepSeek，速度快、成本低）
TEXT_API_KEY=your_deepseek_api_key_here
TEXT_BASE_URL=https://api.deepseek.com/v1
TEXT_MODEL=deepseek-chat

# 视觉模型（推荐 Qwen-VL-Plus 或 GPT-4o）
VISION_API_KEY=your_vision_api_key_here
VISION_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
VISION_MODEL=qwen-vl-plus

# 模型定价（元/千token，用于费用统计）
TEXT_PRICE_INPUT=0.001
TEXT_PRICE_OUTPUT=0.002
VISION_PRICE_INPUT=0.008
VISION_PRICE_OUTPUT=0.008
